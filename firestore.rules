rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Google Play closed-testing signups from flutterclaw.ai (public create only; no reads).
    match /playClosedBetaSignups/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email'])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 320
        && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
